# 后端环境变量
# 复制此文件为 .env 并修改

# 数据库连接
APP_DATABASE_URL=sqlite+aiosqlite:///./data.db

# 调试模式
APP_DEBUG=false

# Keycloak OIDC 配置
APP_OIDC_ISSUER=http://localhost:8080/realms/team-sign-off
APP_OIDC_CLIENT_ID=team-sign-off-frontend
APP_OIDC_CLIENT_SECRET=

# 前端 CORS 允许的源
APP_CORS_ORIGINS=["http://localhost:5173"]